generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String      @id @default(cuid())
  name       String
  aiName     String      @map("ai_name")
  aiGender   String      @map("ai_gender") // "female" | "male"
  toxicLevel   Int         @map("toxic_level") // 1-5
  personality  String      @default("tsundere") // "tsundere" | "yandere" | "kuudere" | "deredere" | "himedere"
  mode         String      @default("anime") // "anime" | "realistic"
  aiPhotoUrl   String?     @map("ai_photo_url")
  createdAt  DateTime    @default(now()) @map("created_at")
  goals      Goal[]
  messages   Message[]
  dailyMoods DailyMood[]

  @@map("users")
}

model Goal {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  title        String
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressLogs ProgressLog[]

  @@map("goals")
}

model ProgressLog {
  id          String   @id @default(cuid())
  goalId      String   @map("goal_id")
  completedAt DateTime @default(now()) @map("completed_at")
  source      String   @default("chat") // "chat" | "manual"
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("progress_logs")
}

model Message {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      String   // "user" | "ai"
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model DailyMood {
  id     String @id @default(cuid())
  userId String @map("user_id")
  date   String // "YYYY-MM-DD"
  mood   String // "manja" | "ngambek" | "sarkas" | "sweet"
  reason String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_moods")
}
