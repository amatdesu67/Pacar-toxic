generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String      @id @default(cuid())
  name         String
  aiName       String      @map("ai_name")
  aiGender     String      @map("ai_gender") // "female" | "male"
  toxicLevel   Int         @map("toxic_level") // 1-5
  personality  String      @default("tsundere") // "tsundere" | "yandere" | "kuudere" | "deredere" | "himedere"
  mode         String      @default("anime") // "anime" | "realistic"
  aiPhotoUrl   String?     @map("ai_photo_url")
  petNameUser  String?     @map("pet_name_user") // panggilan AI ke user
  petNameAi    String?     @map("pet_name_ai")   // panggilan user ke AI
  conversationSummary String?   @map("conversation_summary") // ringkasan chat lama (di luar 50 pesan terakhir)
  summaryUpdatedAt    DateTime? @map("summary_updated_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  messages     Message[]
  dailyMoods   DailyMood[]
  facts        UserFact[]

  @@map("users")
}

model UserFact {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  category  String   // "hobi" | "makanan" | "kerjaan" | "temen" | "keluarga" | "insecurity" | "kebiasaan" | "lainnya"
  content   String   // contoh: "suka kopi tanpa gula"
  source    String   @default("extracted") // "extracted" | "manual"
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_facts")
}

model Message {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      String   // "user" | "ai"
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model DailyMood {
  id     String @id @default(cuid())
  userId String @map("user_id")
  date   String // "YYYY-MM-DD"
  mood   String // "manja" | "ngambek" | "sarkas" | "sweet"
  reason String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_moods")
}
